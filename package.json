{
  "name": "llm-sse",
  "version": "0.5.0",
  "description": "Parse OpenAI Responses and Chat Completions, Anthropic, Gemini and OpenAI-compatible SSE streams into one unified event format. Zero dependencies.",
  "keywords": [
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "deepseek",
    "groq",
    "openrouter",
    "llm",
    "stream",
    "streaming",
    "sse",
    "server-sent-events",
    "tool-calls",
    "reasoning",
    "delta",
    "provider",
    "portability",
    "ai",
    "agents"
  ],
  "license": "MIT",
  "author": "Sebastian Legarraga",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slegarraga/llm-sse.git"
  },
  "homepage": "https://github.com/slegarraga/llm-sse#readme",
  "bugs": {
    "url": "https://github.com/slegarraga/llm-sse/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "fixtures",
    "docs",
    "README.md",
    "ROADMAP.md",
    "GOVERNANCE.md",
    "SUPPORT.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "check": "npm run format:check && npm run typecheck && npm run lint && npm test && npm run build && npm run pack:check && npm run pack:smoke",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pack:check": "npm pack --dry-run --foreground-scripts=false",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "prepublishOnly": "npm run check",
    "prepare": "npm run build"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.4.1",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.8"
  }
}
